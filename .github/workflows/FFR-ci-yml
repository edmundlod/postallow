  # =========================================================================
  # Debian 13 (trixie) — Docker container, no systemd, runs as root
  # --privileged is required: postfix uses chroot(2) for its child processes,
  # which needs CAP_SYS_CHROOT.  Containers have this by default only when
  # --privileged is set.
  # =========================================================================
  debian-13:
    name: Debian 13
    runs-on: ubuntu-24.04
    container:
      image: debian:trixie
      options: --privileged

    steps:
      - uses: actions/checkout@v4

      - name: Install packages
        run: |
          DEBIAN_FRONTEND=noninteractive apt-get update -q
          DEBIAN_FRONTEND=noninteractive apt-get install -y \
            postfix \
            bind9-dnsutils \
            perl libnet-cidr-lite-perl libnetaddr-ip-perl \
            git

      - name: Install spf-tools
        run: |
          git clone --depth=1 \
            https://github.com/lquidfire/spf-tools \
            /usr/local/bin/spf-tools
          chmod +x /usr/local/bin/spf-tools/*.sh

      - name: Install aggregateCIDR.pl
        run: |
          git clone --depth=1 \
            https://github.com/lquidfire/route-summarization \
            /opt/route-summarization
          install -m 755 \
            /opt/route-summarization/aggregateCIDR.pl \
            /usr/local/bin/aggregateCIDR.pl

      - name: Create postallow user and data directory
        run: sh contrib/install.sh

      - name: Install postallow script, host list, and static data
        run: |
          install -m 755 postallow /usr/local/bin/postallow
          install -d -m 755 /etc/postallow
          install -m 644 conf/allowlist_hosts /etc/postallow/allowlist_hosts
          install -d -m 755 /usr/local/share/postallow
          install -m 644 yahoo_static_hosts.txt \
            /usr/local/share/postallow/yahoo_static_hosts.txt

      - name: Write postallow.conf
        run: |
          cat > /etc/postallow/postallow.conf <<'EOF'
          allowlist_hosts=/etc/postallow/allowlist_hosts
          spftoolspath=/usr/local/bin/spf-tools
          postfixpath=/var/lib/postallow
          allowlist=postscreen_spf_allowlist.cidr
          blocklist=postscreen_spf_blocklist.cidr
          yahoo_static_hosts=/usr/local/share/postallow/yahoo_static_hosts.txt
          include_yahoo=yes
          enable_blocklist=no
          EOF

      # In a container there is no syslog daemon.  maillog_file tells postfix
      # to write logs to a plain file instead of syslog (requires postfix >= 3.4,
      # which Debian trixie ships).  Without this postfix start will succeed but
      # log nothing and some distributions will print a warning.
      - name: Configure and start postfix
        run: |
          postconf -e "inet_interfaces = loopback-only"
          postconf -e "maillog_file = /var/log/mail.log"
          touch /etc/aliases /var/log/mail.log
          newaliases
          postfix start
          sleep 2

      - name: Run postallow as postallow user
        run: |
          su -s /bin/sh postallow -c \
            '/usr/local/bin/postallow /etc/postallow/postallow.conf'

      - name: Reload postfix as root (privilege-separated step)
        run: postfix reload

      - name: Verify CIDR output
        run: sh ci/verify.sh /var/lib/postallow/postscreen_spf_allowlist.cidr


  # =========================================================================
  # AlmaLinux 9 — Docker container, no systemd, runs as root
  # RHEL family: package names differ from Debian (bind-utils, not bind9-dnsutils;
  # dnf instead of apt; EPEL needed for some Perl modules).
  # =========================================================================
  almalinux-9:
    name: AlmaLinux 9
    runs-on: ubuntu-24.04
    container:
      image: almalinux:9
      options: --privileged

    steps:
      - uses: actions/checkout@v4

      # epel-release provides perl-Net-CIDR-Lite and perl-NetAddr-IP which are
      # not in the AlmaLinux base or AppStream repos.
      - name: Install packages
        run: |
          dnf install -y epel-release
          dnf install -y \
            postfix \
            bind-utils \
            perl perl-Net-CIDR-Lite perl-NetAddr-IP \
            git

      - name: Install spf-tools
